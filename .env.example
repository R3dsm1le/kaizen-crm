# ------------------------------------------------------------------
# Kaizen CRM — environment
# Only DATABASE_URL is required. Everything else is optional and can
# also be configured in Settings inside the app.
# ------------------------------------------------------------------

# Postgres connection string (Supabase → Connect → pooler string, host
# ends in pooler.supabase.com). The POSTGRES_URL name injected by the
# Vercel × Supabase integration is picked up automatically too.
DATABASE_URL=

# Optional: Supabase Auth (protects the app behind a login).
# Without these the app runs in open local mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: shared secret for /api/cron (Vercel sets the header automatically).
CRON_SECRET=

# Optional: Gemini API key fallback (Settings → AI takes priority).
GEMINI_API_KEY=
