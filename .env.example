# ------------------------------------------------------------------
# Kaizen CRM — environment
# EVERYTHING here is optional. The database is configured on the
# first-run setup screen, and all integrations (AI, email, lead
# sources) live in Settings inside the app.
# ------------------------------------------------------------------

# Postgres connection string. Overrides the value saved by the setup
# screen — REQUIRED on serverless hosts like Vercel (their filesystem
# is ephemeral, so the setup screen can't persist it there).
# Supabase → Project Settings → Database → use the "Transaction" pooler URL.
DATABASE_URL=

# Optional single-code access gate (no user accounts). Set this on a
# public deployment so strangers with your link can't use your backend,
# AI, or email quota. Every visitor enters this code once per device.
APP_ACCESS_CODE=

# Optional: shared secret for /api/cron (Vercel sets the header automatically).
CRON_SECRET=

# Optional: Gemini API key fallback (Settings → AI takes priority).
GEMINI_API_KEY=
